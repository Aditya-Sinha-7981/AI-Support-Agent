# Copy this to .env and fill in your keys
# Never commit .env to git

# LLM — options: gemini | groq
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_key_here
# Examples: gemini-2.5-flash, gemini-2.5-flash-lite, gemini-3-flash-preview
GEMINI_MODEL=gemini-2.5-flash
# Lower thinking budget improves responsiveness for streaming-like UX.
GEMINI_THINKING_BUDGET=0
GEMINI_MAX_OUTPUT_TOKENS=512
# RAG embeddings (Gemini) — required for ingest + retrieval even if LLM_PROVIDER=groq
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GROQ_API_KEY=your_key_here

# STT — options: local | deepgram
# M1: use local
# M3: ALWAYS use deepgram (never run whisper locally)
STT_PROVIDER=local
DEEPGRAM_API_KEY=your_key_here

# TTS — options: edge | elevenlabs
TTS_PROVIDER=edge
ELEVENLABS_API_KEY=your_key_here
